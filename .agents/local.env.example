# j2534-logger — Local Environment Configuration
# Copy this file to .agents/local.env and fill in your values.
# .agents/local.env is gitignored and should never be committed.

# ─── Device Configuration ─────────────────────────────────────────────
# J2534_DEVICE_NAME=<name of your J2534 device as shown in registry>
# J2534_DLL_PATH=<path to the real J2534 DLL>

# ─── Network / Logging ────────────────────────────────────────────────
# LOG_SERVER_HOST=127.0.0.1
# LOG_SERVER_PORT=8234

# ─── Build Environment ────────────────────────────────────────────────
# MSBUILD_PATH=C:\Program Files\Microsoft Visual Studio\2022\Community\MSBuild\Current\Bin\MSBuild.exe
# VS_VERSION=2022
